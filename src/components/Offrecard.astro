---
import PbImages from "./PbImages.astro";
const { offre } = Astro.props;
---

<article
    class={`offre-card relative rounded-xl border-2 border-indigo-950 p-5 shadow-sm transition-all ${
        offre.favori ? "bg-indigo-100" : "bg-gray-100"
    }`}
    data-favori={offre.favori.toString()}
>
    <header class="flex items-start justify-between gap-4">
        <div>
            <h2 class="text-lg font-semibold text-indigo-950">
                {offre.nomMaison}
            </h2>
        </div>
    </header>

    <div class="mt-4">
        <PbImages record={offre} imageField="images" width={400} height={250} />
    </div>

    <div class="mt-3">
        <a
            href={`/offres/${offre.id}`}
            class="inline-block rounded-lg bg-indigo-800 px-4 py-2 font-semibold text-white"
        >
            Voir plus
        </a>
    </div>

    <!-- Bouton Favori -->

    <button
        class="favoriteButton absolute top-3 right-3 p-2"
        data-offre={JSON.stringify(offre)}
        type="button"
    >
        <img
            id="favorite-icon"
            src={offre.favori ? "/favorite_filled.png" : "/favorite.png"}
            alt="Favorite Icon"
            class="h-6 w-6"
        />
    </button>
</article>

<script>
    //@ts-nocheck
    import { setFavori } from "../backend.mjs";

    const favoriteButtons = document.querySelectorAll(".favoriteButton");

    favoriteButtons.forEach((button) => {
        button.addEventListener("click", () => {
            const offreData = JSON.parse(button.dataset.offre || "{}");
            const newFavori = !offreData.favori;

            setFavori(offreData);

            const favIcon = button.querySelector("#favorite-icon");

            if (favIcon) {
                favIcon.src = newFavori
                    ? "/favorite_filled.png"
                    : "/favorite.png";
            }

            offreData.favori = newFavori;
            button.dataset.offre = JSON.stringify(offreData);
        });
    });
</script>
