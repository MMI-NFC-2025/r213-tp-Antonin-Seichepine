---
import Layout from "../../layouts/Layout.astro";
import Offrecard from "../../components/Offrecard.astro";
import { getOffres } from "../../backend.mjs";

const offres = await getOffres();
---

<Layout titre="Nos offres">
    <h1 class="mb-8 text-center text-3xl font-bold text-indigo-950">
        Nos offres
    </h1>

    <div class="mb-6 flex justify-end">
        <a
            href="/offres/add"
            class="rounded-lg bg-indigo-800 px-4 py-2 font-semibold text-white"
        >
            Ajouter une offre
        </a>
    </div>

    <section class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {offres.map((offre) => <Offrecard offre={offre} />)}
    </section>
</Layout>
