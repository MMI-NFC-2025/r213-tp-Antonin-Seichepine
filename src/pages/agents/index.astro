---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../backend.mjs";

const agents = await getAgents();
---

<Layout titre="Agents">
    <h1 class="text-3xl font-bold text-indigo-950">Nos agents</h1>

    <section class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {agents.map((agent) => (
            <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-xl font-semibold text-indigo-950">
                    {agent.prenom} {agent.nom}
                </h2>

                <p class="mt-2 text-slate-700">{agent.email}</p>

                <a
                    href={`/agents/${agent.id}`}
                    class="mt-4 inline-block rounded-lg bg-indigo-950 px-4 py-2 text-white transition hover:opacity-80"
                >
                    Voir ses offres
                </a>
            </article>
        ))}
    </section>
</Layout>